package mx.uam.ayd.proyecto.negocio;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.stereotype.Service;
import org.springframework.transaction.annotation.Transactional;

import mx.uam.ayd.proyecto.datos.ProductoRepository;
import mx.uam.ayd.proyecto.negocio.modelo.Bitacora;
import mx.uam.ayd.proyecto.negocio.modelo.Producto;

/**
 * Servicio para gestionar la lógica de negocio de los productos.
 */
@Service
public class ServicioProducto {

    private final ProductoRepository productoRepository;
    private final ServicioBitacora servicioBitacora; // <--- Se agrega esta declaración

    @Autowired
    public ServicioProducto(ProductoRepository productoRepository, ServicioBitacora servicioBitacora) {
        this.productoRepository = productoRepository;
        this.servicioBitacora = servicioBitacora;
    }

    /**
     * Actualiza el precio de un producto y registra el movimiento en la bitácora (HU-09).
     * 
     * @param idProducto Identificador del producto
     * @param nuevoPrecio Nuevo precio a asignar
     * @return El objeto Bitacora con el registro del cambio
     */
    @Transactional
    public Bitacora actualizarPrecioProducto(long idProducto, double nuevoPrecio) {
        // 1. Buscar el producto
        Producto producto = productoRepository.findById(idProducto)
                .orElseThrow(() -> new IllegalArgumentException("No se encontró el producto con ID: " + idProducto));

        double precioAnterior = producto.getPrecio(); // Asegúrate de ajustar el getter según tu entidad Producto

        // 2. Actualizar el precio del producto y guardarlo
        producto.setPrecio(nuevoPrecio); // Ajusta el setter según tu entidad Producto
        productoRepository.save(producto);

        // 3. Registrar en la bitácora a través del servicio inyectado
        return servicioBitacora.registrarCambioPrecio(idProducto, precioAnterior, nuevoPrecio);
    }
}