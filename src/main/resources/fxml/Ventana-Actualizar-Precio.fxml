package mx.uam.ayd.proyecto.presentacion.actualizarPrecio;

import org.springframework.stereotype.Component;

import javafx.fxml.FXML;
import javafx.scene.control.Button;
import javafx.scene.control.Label;
import javafx.scene.control.TextField;
import mx.uam.ayd.proyecto.negocio.modelo.Producto;

/**
 * Ventana JavaFX para la Actualización de Precios (HU09).
 *
 * @author Yamelin Larios Nepomuseno
 */
@Component
public class VentanaActualizarPrecio {

    private ControlActualizarPrecio control;

    // Componentes inyectados desde el archivo FXML
    @FXML
    private TextField txtIdProducto;

    @FXML
    private Button btnBuscar;

    @FXML
    private Label lblNombreProducto;

    @FXML
    private Label lblPrecioActual;

    @FXML
    private TextField txtNuevoPrecio;

    @FXML
    private Label lblFeedback;

    @FXML
    private Button btnActualizar;

    /**
     * Asigna el control que manejará las acciones de esta ventana.
     * 
     * @param control
     */
    public void setControl(ControlActualizarPrecio control) {
        this.control = control;
    }

    /**
     * Muestra la ventana y resetea los campos.
     */
    public void muestra() {
        limpiarCampos();
        // Aquí agregas la lógica para hacer visible el Stage de JavaFX si tu proyecto usa Stage
    }

    /**
     * Evento asociado al botón "Buscar" (#onBuscarProducto)
     */
    @FXML
    public void onBuscarProducto() {
        String textoId = txtIdProducto.getText().trim();

        if (textoId.isEmpty()) {
            mostrarMensaje("Por favor ingresa un ID de producto.", true);
            return;
        }

        try {
            long idProducto = Long.parseLong(textoId);
            Producto producto = control.buscarProducto(idProducto);

            if (producto == null) {
                mostrarMensaje("No se encontró ningún producto con ID: " + idProducto, true);
                lblNombreProducto.setText("-");
                lblPrecioActual.setText("-");
            } else {
                lblNombreProducto.setText(producto.getNombre());
                lblPrecioActual.setText("$" + String.format("%.2f", producto.getPrecio()));
                ocultarMensaje();
            }

        } catch (NumberFormatException e) {
            mostrarMensaje("El ID de producto debe ser un número entero válido.", true);
        }
    }

    /**
     * Evento asociado al botón "Actualizar Precio" (#onActualizarPrecio)
     */
    @FXML
    public void onActualizarPrecio() {
        String textoId = txtIdProducto.getText().trim();
        String textoNuevoPrecio = txtNuevoPrecio.getText().trim();

        if (textoId.isEmpty() || textoNuevoPrecio.isEmpty()) {
            mostrarMensaje("Por favor busca un producto y captura el nuevo precio.", true);
            return;
        }

        try {
            long idProducto = Long.parseLong(textoId);
            double nuevoPrecio = Double.parseDouble(textoNuevoPrecio);

            // Invocación al control
            Producto productoActualizado = control.actualizarPrecio(idProducto, nuevoPrecio);

            // Actualizar la interfaz
            lblPrecioActual.setText("$" + String.format("%.2f", productoActualizado.getPrecio()));
            txtNuevoPrecio.clear();
            mostrarMensaje("¡Precio actualizado correctamente a $" + productoActualizado.getPrecio() + "!", false);

        } catch (NumberFormatException e) {
            mostrarMensaje("El nuevo precio debe ser un número decimal válido (ej. 15.50).", true);
        } catch (IllegalArgumentException e) {
            mostrarMensaje(e.getMessage(), true);
        }
    }

    /**
     * Limpia el formulario
     */
    private void limpiarCampos() {
        txtIdProducto.clear();
        lblNombreProducto.setText("-");
        lblPrecioActual.setText("-");
        txtNuevoPrecio.clear();
        ocultarMensaje();
    }

    /**
     * Muestra mensajes de error o éxito en el Label de Feedback
     */
    private void mostrarMensaje(String mensaje, boolean esError) {
        lblFeedback.setText(mensaje);
        lblFeedback.setVisible(true);
        if (esError) {
            lblFeedback.setStyle("-fx-background-color: #ffcdd2; -fx-text-fill: #b71c1c; -fx-padding: 5;");
        } else {
            lblFeedback.setStyle("-fx-background-color: #c8e6c9; -fx-text-fill: #1b5e20; -fx-padding: 5;");
        }
    }

    private void ocultarMensaje() {
        lblFeedback.setVisible(false);
        lblFeedback.setText("");
    }
}