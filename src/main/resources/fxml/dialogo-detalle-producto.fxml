<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>

<VBox prefWidth="400.0" spacing="20.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1">
   <children>
      <!-- Título del Diálogo -->
      <Label text="Detalle de Existencias">
         <font>
            <Font name="System Bold" size="16.0" />
         </font>
      </Label>

      <!-- Contenedor de información detallada -->
      <GridPane hgap="10.0" vgap="15.0">
        <columnConstraints>
          <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="120.0" />
          <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="200.0" />
        </columnConstraints>
        <rowConstraints>
          <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
          <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
          <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
          <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
        </rowConstraints>
         <children>
            <Label text="Clave Única (RN-08):" GridPane.rowIndex="0" />
            <Label fx:id="lblClave" text="---" GridPane.columnIndex="1" GridPane.rowIndex="0">
               <font><Font name="System Italic" size="13.0" /></font>
            </Label>

            <Label text="Nombre:" GridPane.rowIndex="1" />
            <Label fx:id="lblNombre" text="---" wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="1" />

            <Label text="Existencia Actual:" GridPane.rowIndex="2" />
            <Label fx:id="lblStockActual" text="0" textFill="#d32f2f" GridPane.columnIndex="1" GridPane.rowIndex="2">
               <font><Font name="System Bold" size="14.0" /></font>
            </Label>

            <Label text="Límite Mínimo:" GridPane.rowIndex="3" />
            <Label fx:id="lblStockMinimo" text="0" GridPane.columnIndex="1" GridPane.rowIndex="3" />
         </children>
      </GridPane>

      <Separator prefWidth="200.0" />

      <!-- Botonera -->
      <HBox alignment="CENTER_RIGHT">
         <children>
            <Button fx:id="btnCerrar" mnemonicParsing="false" onAction="#handleCerrar" prefWidth="100.0" text="Aceptar" />
         </children>
      </HBox>
   </children>
   <padding>
      <Insets bottom="25.0" left="25.0" right="25.0" top="25.0" />
   </padding>
</VBox>
