<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="10"
      style="-fx-padding: 15px;"
      xmlns="http://javafx.com/javafx/24.0.1"
      xmlns:fx="http://javafx.com/fxml/1">

    <Label
        style="-fx-font-size: 18px; -fx-font-weight: bold;"
        text="Consultar inventario" />

    <HBox spacing="10">
        <Label text="Nombre del producto:" />

        <TextField
            fx:id="textFieldNombre"
            promptText="Escribe el nombre del producto"
            HBox.hgrow="ALWAYS" />

        <Button
            onAction="#onBuscarProducto"
            text="Buscar" />

        <Button
            onAction="#onMostrarTodos"
            text="Mostrar todos" />
    </HBox>

    <TableView
        fx:id="tablaProductos"
        prefHeight="400"
        prefWidth="750">

        <columns>
            <TableColumn
                fx:id="colId"
                prefWidth="80"
                text="ID" />

            <TableColumn
                fx:id="colNombre"
                prefWidth="170"
                text="Nombre" />

            <TableColumn
                fx:id="colTipoProducto"
                prefWidth="130"
                text="Tipo" />

            <TableColumn
                fx:id="colMarca"
                prefWidth="120"
                text="Marca" />

            <TableColumn
                fx:id="colCategoria"
                prefWidth="120"
                text="Categoría" />

            <TableColumn
                fx:id="colPrecio"
                prefWidth="100"
                text="Precio" />

            <TableColumn
                fx:id="colExistencia"
                prefWidth="100"
                text="Existencia" />
        </columns>
    </TableView>

    <HBox spacing="10">
        <Button
            onAction="#onRegresar"
            text="Regresar" />
    </HBox>

</VBox>