<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="449.0" prefWidth="591.0" spacing="10" style="-fx-padding: 15px;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1">
    
    <Label style="-fx-font-size: 18px; -fx-font-weight: bold;" text="Tlapaleria: La nueva" />
    
    <Button onAction="#handleAgregarUsuario" style="-fx-min-width: 200px; -fx-min-height: 30px;" text="Consultar inventario" />

    <Button onAction="#handleListarInventario" style="-fx-min-width: 200px; -fx-min-height: 30px;" text="Consultar Bajo Stock" />

    <Button onAction="#handleRegistrarMercancia" style="-fx-min-width: 200px; -fx-min-height: 30px;" text="Consultar carrito" />

    <Button onAction="#handleListarUsuarios" style="-fx-min-width: 200px; -fx-min-height: 30px;" text="Actualizar el precio de los productos" />
    
    <Button onAction="#handleListarGrupos" style="-fx-min-width: 200px; -fx-min-height: 30px;" text="Devolver productos dañados" />
    
</VBox>
